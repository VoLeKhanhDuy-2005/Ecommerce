{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "module": "ESNext",
    "skipLibCheck": true,
    "allowJs": true,          // <--- Thêm dòng này để cho phép file .js/.jsx
    "checkJs": false,         // <--- Thêm dòng này để không bắt lỗi cú pháp file .js

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": false,          // <--- Chuyển thành false nếu dự án dùng thuần JS để tránh ép kiểu nghiêm ngặt
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src", "src/**/*"] // <--- Quét sâu hơn vào toàn bộ cấu trúc thư mục con
}
